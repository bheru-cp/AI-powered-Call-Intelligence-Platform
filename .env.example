# OpenAI (Whisper + GPT) — never commit real keys
OPENAI_API_KEY=
# Chat model for structured analysis (optional; default: gpt-4o-mini).
# Use GPT-4o family (e.g. gpt-4o-mini, gpt-4o). Do not use o1/o3 reasoning models here.
# OPENAI_ANALYSIS_MODEL=gpt-4o-mini

# Supabase (create project at https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=
# Optional: only needed if you add a browser Supabase client (this repo uses the service role on the server)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only: Storage upload + DB writes (keep secret)
SUPABASE_SERVICE_ROLE_KEY=

# Optional: public URL for this app (used in metadata)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Without Supabase, calls/audio are stored under .data/call-intelligence/ (gitignored).
# If the Node process cannot write there (e.g. www-data under /var/www), the app falls back to
# /tmp/call-intelligence-platform (see server logs). Prefer: chown/chmod .data or set:
# CALL_INTEL_LOCAL_DATA_DIR=/var/lib/call-intelligence
# On serverless hosts, disable local disk so the app returns 503 until Supabase is set:
# CALL_INTEL_DISABLE_LOCAL_STORE=true
